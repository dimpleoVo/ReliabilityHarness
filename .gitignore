# python
__pycache__/
*.pyc

# ── Do NOT ignore: .env template, configs, data fixtures, directory scaffolding ──
# Un-ignore outputs/ subdirectories FIRST (parent must be un-ignored before contents)
!.env.example
!configs/*.yaml
!data/tasks/*.json
!data/reliability_tasks.json
!data/.gitkeep
!data/tasks/.gitkeep
!outputs/.gitkeep
!outputs/runs/
!outputs/runs/.gitkeep
!outputs/reports/
!outputs/reports/.gitkeep
!outputs/predictions/
!outputs/predictions/.gitkeep
!outputs/benchmark_results/
!outputs/benchmark_results/.gitkeep
outputs/benchmark_results/*.json
!outputs/benchmark_results/.gitkeep
