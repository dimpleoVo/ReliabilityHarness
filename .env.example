# Copy this file to .env at repo root and fill in your values.
# .env is local-only and must NEVER be committed to git.
# docker/docker-compose.yml reads ../.env (repo root .env).

# --- LLM (Benchmark-3 generation mode) ---
# Required for: python -m reliability_harness.experiments.run_benchmark --generate
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# --- Legacy LLM (OpenAI / proxy) — deprecated, not used by Benchmark-3 ---
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1   # override if using a proxy / Azure

# --- Sandbox ---
SANDBOX_BASE_URL=http://sandbox:9000

# --- Dataset ---
# Primary override — set this if your task JSON is not at data/tasks/reliability_tasks.json
# RELIABILITY_HARNESS_DATASET_PATH=/path/to/data/tasks/reliability_tasks.json

# Secondary override (also accepted)
# DATASET_PATH=/path/to/data/tasks/reliability_tasks.json

# Deprecated explicit alias — only used when explicitly set by user; does NOT auto-fallback to ReActX/data/.
# Prefer RELIABILITY_HARNESS_DATASET_PATH instead.
# REACTX_DATASET_PATH=/path/to/reliability_tasks.json
